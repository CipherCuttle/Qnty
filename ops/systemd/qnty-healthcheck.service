[Unit]
Description=Qnty Health Check - Freshness, Disk, Service Liveness
After=network.target

[Service]
Type=oneshot
User=qnty
Group=qnty
WorkingDirectory=/srv/qnty/repo
Environment="PATH=/srv/qnty/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="VIRTUAL_ENV=/srv/qnty/venv"
ExecStart=/srv/qnty/repo/ops/bin/qnty-healthcheck.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=qnty-healthcheck
# Timeout after 5 minutes
TimeoutSec=300
