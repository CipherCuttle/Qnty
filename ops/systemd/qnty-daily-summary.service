[Unit]
Description=Qnty Daily Summary - Viktor-Facing Daily Status
After=network.target

[Service]
Type=oneshot
User=qnty
Group=qnty
WorkingDirectory=/srv/qnty/repo
Environment="PATH=/srv/qnty/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="VIRTUAL_ENV=/srv/qnty/venv"
ExecStart=/srv/qnty/repo/ops/bin/qnty-daily-summary.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=qnty-daily-summary
# Timeout after 10 minutes
TimeoutSec=600
